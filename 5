def phone_card():
    '''
    Enters an amount and displays a value based on it
    '''
    cost = int(input()) 
    
    if cost == 5 or cost == 10:
        return cost #without bonus
    elif cost == 25:
        return cost + 3 #bonus 3$
    elif cost == 50:
        return cost + 8 #bonus 8$
    elif cost == 100:
        return cost + 20 bonus 20$
    else:
        print('Wrong card cost') #if there no such cost


phone_card()
